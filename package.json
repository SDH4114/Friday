{
  "name": "@sdh4114/raya",
  "version": "0.1.0",
  "description": "Raya is an open-source personal AI PC assistant and coding harness for the terminal.",
  "type": "module",
  "bin": {
    "raya": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "builtin-skills",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && chmod +x dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "prepack": "npm run build",
    "start": "node dist/cli/index.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "raya",
    "ai-agent",
    "coding-agent",
    "cli",
    "codex",
    "chatgpt",
    "telegram",
    "pc-assistant",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
