{
  "name": "@sdh4114/raya",
  "version": "0.1.1",
  "description": "Raya is an open-source AI coding agent harness for the terminal.",
  "type": "module",
  "bin": {
    "raya": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "install.sh",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc && chmod +x dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "prepack": "npm run build",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "raya",
    "ai-agent",
    "coding-agent",
    "cli",
    "codex",
    "chatgpt"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "commander": "^14.0.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
